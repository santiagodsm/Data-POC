# Copy this file to .env and edit. Never commit .env.
# cp infra/env/.env.example infra/env/.env

# ===== App =====
OPENAI_API_KEY=your-openai-api-key-here
ALLOW_WRITES=false
MASK_PII=true

# ===== Postgres (local dev defaults) =====
PGHOST=db
PGPORT=5432
PGDATABASE=datacopilot
PGUSER=datacopilot
PGPASSWORD=changeme

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== MinIO (local dev defaults) =====
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=changeme
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_UPLOADS=uploads
MINIO_BUCKET_ARTIFACTS=artifacts
MINIO_BUCKET_EVIDENCE=evidence
